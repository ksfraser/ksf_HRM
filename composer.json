{
    "name": "ksfraser/ksf_hrm",
    "description": "KSF Human Resource Management Module",
    "type": "project",
    "license": "GPL-3.0",
    "require": {
        "php": "^8.1",
        "ksfraser/database": "*",
        "ksfraser/ksf-modules-dao": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.0",
        "willdurand/negotiation": "^3.1",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Ksf\\HRM\\": "src/",
            "Ksf\\HRM\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../Database"
        },
        {
            "type": "path",
            "url": "../ksf_ModulesDAO"
        }
    ]
}
