{
    "name": "ksfraser/ksf_hrm",
    "description": "KSF Human Resource Management Library",
    "type": "library",
    "license": "GPL-3.0",
    "require": {
        "php": "^8.1",
        "ksfraser/database": "*",
        "ksfraser/ksf-modules-dao": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\HRM\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\HRM\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../Database"},
        {"type": "path", "url": "../ksf_ModulesDAO"}
    ]
}
